{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2022",
		"outDir": "out",
		"rootDir": ".",
		"lib": [
			"ES2022"
		],
		"sourceMap": true,
		"strict": true,
		"skipLibCheck": true
	},
	"include": ["src/**/*", "test/**/*"],
	"exclude": ["src/webview/**/*", "node_modules", "vite.config.webview.mts"]
}
