{
  "name": "the-seed-vscode",
  "displayName": "the-seed-vscode",
  "description": "",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.97.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "the-seed-sidebar",
          "title": "The Seed",
          "icon": "media/the-seed-icon.svg"
        }
      ]
    },
    "views": {
      "the-seed-sidebar": [
        {
          "type": "webview",
          "id": "the-seed.mainView",
          "name": "The Seed"
        }
      ]
    },
    "commands": [
      {
        "command": "the-seed.createResourcePak",
        "title": "The Seed: Create ResourcePak"
      },
      {
        "command": "the-seed.configureProject",
        "title": "The Seed: Configure Project"
      },
      {
        "command": "the-seed.showConfig",
        "title": "The Seed: Show Config"
      },
      {
        "command": "the-seed.listScopes",
        "title": "The Seed: List Scopes"
      },
      {
        "command": "the-seed.addScope",
        "title": "The Seed: Add Scope"
      },
      {
        "command": "the-seed.editScope",
        "title": "The Seed: Edit Scope"
      },
      {
        "command": "the-seed.deleteScope",
        "title": "The Seed: Delete Scope"
      },
      {
        "command": "the-seed.createComponentTemplate",
        "title": "The Seed: Create Component Template"
      },
      {
        "command": "the-seed.createSystemTemplate",
        "title": "The Seed: Create System Template"
      },
      {
        "command": "the-seed.createProgramTemplate",
        "title": "The Seed: Create Program Template"
      },
      {
        "command": "the-seed.buildNative",
        "title": "The Seed: Build Native"
      },
      {
        "command": "the-seed.buildWindows",
        "title": "The Seed: Build Windows"
      },
      {
        "command": "the-seed.buildIncremental",
        "title": "The Seed: Build (Incremental)"
      },
      {
        "command": "the-seed.buildNativeRecursive",
        "title": "The Seed: Build Native (Recursive)"
      },
      {
        "command": "the-seed.buildWindowsRecursive",
        "title": "The Seed: Build Windows (Recursive)"
      },
      {
        "command": "the-seed.addResource",
        "title": "The Seed: ResourcePak Add Resource"
      },
      {
        "command": "the-seed.buildResourcePak",
        "title": "The Seed: ResourcePak Build"
      },
      {
        "command": "the-seed.checkDependencies",
        "title": "The Seed: Check Dependencies"
      },
      {
        "command": "the-seed.installDependencies",
        "title": "The Seed: Install Dependencies"
      },
      {
        "command": "the-seed.packageProject",
        "title": "The Seed: Package Projects"
      },
      {
        "command": "the-seed.createSigningCert",
        "title": "The Seed: Create Signing Certificate"
      },
      {
        "command": "the-seed.importSigningCert",
        "title": "The Seed: Import Signing Certificate"
      },
      {
        "command": "the-seed.signFile",
        "title": "The Seed: Sign File"
      },
      {
        "command": "the-seed.verifySignature",
        "title": "The Seed: Verify Signature"
      },
      {
        "command": "the-seed.signingCertInfo",
        "title": "The Seed: Signing Certificate Info"
      },
      {
        "command": "the-seed.exportSigningCert",
        "title": "The Seed: Export Signing Certificate"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "the-seed.signFile",
          "group": "the-seed@1",
          "when": "!explorerResourceIsFolder"
        },
        {
          "command": "the-seed.verifySignature",
          "group": "the-seed@2",
          "when": "!explorerResourceIsFolder"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p ./",
    "build:webview": "vite build --config vite.config.webview.mts",
    "build": "npm run compile && npm run build:webview",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sinon": "^21.0.0",
    "@types/vscode": "^1.97.0",
    "@types/vscode-webview": "^1.57.5",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.19.0",
    "sinon": "^21.0.1",
    "typescript": "^5.7.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@metaverse-systems/the-seed": "file:../the-seed",
    "@vscode-elements/elements": "^2.5.0",
    "@vscode-elements/react-elements": "^2.4.0",
    "fs-extra": "^11.3.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
